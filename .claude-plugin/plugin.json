{
  "name": "docpler",
  "version": "0.1.0",
  "description": "Convert Korean HWP documents to Markdown",
  "author": {
    "name": "docpler",
    "url": "https://github.com/docpler"
  },
  "repository": "https://github.com/docpler/docpler-claude-plugin",
  "license": "MIT",
  "keywords": ["hwp", "markdown", "korean", "document", "converter"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/install.sh"
          }
        ]
      }
    ]
  }
}
